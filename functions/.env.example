# 포트원 결제 (백엔드)
# PORTONE_API_KEY=
# PORTONE_API_SECRET=

# 카카오 로그인 (백엔드 콜백)
# 카카오 개발자 콘솔 > 앱 설정 > 앱 키 > REST API 키
# KAKAO_REST_API_KEY=
# 선택: 보안 강화 시 클라이언트 시크릿 (카카오 콘솔에서 활성화한 경우 필수)
# KAKAO_CLIENT_SECRET=
# 콜백 기준 URL (카카오 콘솔 Redirect URI와 동일 origin이어야 함)
# KAKAO_REDIRECT_BASE_URL=https://apibid-oytjv32jna-du.a.run.app
# 기본 프론트엔드 URL (state 미전달 시 콜백 후 리다이렉트 기본값)
# FRONTEND_URL=https://bcsa.co.kr

# 비밀번호 재설정 메일 (SMTP — 네이버/구글 등)
# SMTP_HOST=smtp.naver.com
# SMTP_PORT=465
# SMTP_USER=your-email@naver.com
# SMTP_PASS=앱비밀번호_또는_SMTP비밀번호
# SMTP_FROM_NAME=부산청년사업가들
# SMTP_FROM_EMAIL=your-email@naver.com

# 비밀번호 재설정 완료 후 이동·메일 링크용 페이지 (미설정 시 bcsa.co.kr)
# PASSWORD_RESET_PAGE_URL=https://bcsa.co.kr/auth/reset-password

# SMTP 미설정 시 Firebase 기본 메일(한국어) 폴백용 — Firebase 웹 API 키
# FIREBASE_WEB_API_KEY=
