# 프론트엔드 환경 변수 예시
# 복사 후 .env.development 또는 .env.local 로 저장하여 사용

# API 기본 URL (필수)
# - 배포 API 사용: https://apibid-oytjv32jna-du.a.run.app
# - 로컬 에뮬레이터: http://127.0.0.1:5001/bcsa-b190f/asia-northeast3/apiBid
# 이미지 업로드 시 WebP(sharp)는 /api/images/encode-webp 로 서버 변환(위 URL 필요)
VITE_API_URL=https://apibid-oytjv32jna-du.a.run.app

# 포트원(구 아임포트) 결제 (유료 프로그램 결제 시 사용)
# 포트원 관리자(https://admin.portone.io) → 연동 정보 → 식별코드·API Keys / 채널 관리
# VITE_PORTONE_IMP_CODE=store-xxx 또는 imp12345678 (가맹점 식별코드)
# VITE_PORTONE_CHANNEL_KEY=channel-key-xxx (채널 관리에서 사용할 결제 채널 키, 실연동/테스트별로 설정)
# VITE_PORTONE_IMP_CODE=
# VITE_PORTONE_CHANNEL_KEY=

# ----------------------------------------
# Firebase Functions (결제 취소 API용, 서버 전용)
# Cloud Run/Functions 배포 시 환경 변수 또는 Secret Manager에 설정
# 포트원 관리자(https://admin.portone.io) → 연동 정보 → API Keys에서 발급
# PORTONE_API_KEY=   # REST API Key (imp_key)
# PORTONE_API_SECRET=   # REST API Secret (imp_secret)

# ----------------------------------------
# 비밀번호 재설정 메일 (Functions 서버 전용)
# 세련된 한국어 HTML 메일을 안정적으로 발송하려면 SMTP 설정이 필요합니다.
# 네이버: 메일 환경설정에서 SMTP 사용 설정 + 앱 비밀번호 발급 후 입력
# SMTP_HOST=smtp.naver.com
# SMTP_PORT=465
# SMTP_USER=your-email@naver.com
# SMTP_PASS=앱비밀번호_또는_SMTP비밀번호
# SMTP_FROM_NAME=부산청년사업가들
# SMTP_FROM_EMAIL=your-email@naver.com
# PASSWORD_RESET_PAGE_URL=https://bcsa-b190f.web.app/auth/reset-password
# SITE_CONTINUE_URL=https://bcsa-b190f.web.app

